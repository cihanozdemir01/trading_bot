# Binance API Ayarları (Testnet varsayılan olarak açık)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
USE_TESTNET=True

# Telegram Bildirim Ayarları
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Risk Yönetimi Ayarları
MAX_RISK_PER_TRADE_PCT=1.0  # İşlem başına maksimum bakiye riski %1
MAX_DAILY_LOSS_PCT=3.0     # Günlük maksimum zarar kapatma sınırı %3
MAX_OPEN_POSITIONS=3        # Aynı anda açık olabilecek maksimum pozisyon sayısı
DEFAULT_LEVERAGE=5         # Varsayılan kaldıraç (Futures işlemleri için)

# Veritabanı
DATABASE_URL=sqlite:///./trading_bot.db
